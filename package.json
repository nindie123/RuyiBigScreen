{
  "name": "ruyibigscreen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue,.js --fix",
    "format": "prettier --write src",
    "lint:style": "stylelint src/**/*.scss --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --headed"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
